    "dev:client": "cd client && npm run dev"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "compression": "1.8.1",
    "cors": "2.8.5",
    "dotenv": "16.4.1",
    "express": "4.18.2",
    "jsonwebtoken": "9.0.2",
    "knex": "3.1.0",
    "pg": "8.20.0",
    "sqlite3": "5.1.7"
  }
}
